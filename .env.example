# OpenCode Go API Configuration
# Copy this file to .env and fill in your values.

# Required: OpenCode Go API key
OPENCODE_GO_API_KEY=your-key-here

# Optional: API base URL (defaults to https://opencode.ai/zen/go/v1)
# OPENCODE_GO_BASE_URL=https://opencode.ai/zen/go/v1

# Optional: Default model (defaults to deepseek-v4-flash)
MODEL=deepseek-v4-flash

# Optional: High-tier model for heavyweight analysis members (defaults to deepseek-v4-pro)
# HIGH_MODEL=deepseek-v4-pro

# Optional: Max tokens per member response (defaults to 8192)
MAX_TOKENS=8192

# Optional: Temperature for member responses (defaults to 0.7)
# TEMPERATURE=0.7
